# Jitsi JaaS Configuration
# Ottieni queste credenziali dal tuo account JaaS su https://jaas.8x8.vc/

# Il tuo App ID JaaS (formato: vpaas-magic-cookie-xxxxx)
JAAS_APP_ID=

# Il tuo Key ID JaaS
JAAS_KEY_ID=your-key-id-here

# La tua Private Key per firmare i JWT (formato PEM)
# Nota: Sostituisci \n con newline reali o usa il formato multilinea
JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----"

# Porta del server (opzionale, default: 3000)
PORT=3000

# URL pubblico del server (per generare i link meeting)
# In locale: http://localhost:3000
# In produzione: https://tuo-dominio.com
SERVER_URL=http://localhost:3000

# MeshCentral Admin Credentials (per creare guest link automatici)
MESHCENTRAL_ADMIN_USER=admin
MESHCENTRAL_ADMIN_PASS=your_admin_password_here

# MeshCentral Configuration (opzionale - per controllo remoto)
# URL del tuo server MeshCentral
MESHCENTRAL_URL=https://your-meshcentral-server.com

# Login Token Key di MeshCentral
# Genera con: node meshcentral --loginTokenKey
# Questo token permette di generare login token temporanei
MESHCENTRAL_TOKEN_KEY=your-meshcentral-token-key-here
